# Copy to `.env` and fill in (never commit `.env`).
# Used by master_connections/run.py via load_dotenv.

# Burak uses both; Abuzar AI (run_fresh_puzzle) uses Claude → ANTHROPIC_API_KEY required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional — Adreama / OpenAI chat defaults:
# OPENAI_CHAT_MODEL=gpt-4o

# Optional — NYT archive hash guard for all master-generated puzzles (default: abuzar_AI-Connections/data/nyt_blocklist.json).
# MASTER_NYT_BLOCKLIST_PATH=/absolute/path/to/nyt_blocklist.json

# Optional — Abuzar AI (subprocess inherits these from master_connections/.env via run.py load_dotenv)
#
# Fastest tiers (Anthropic IDs change over time — check docs):
#   CLAUDE_GROUP_GENERATOR_MODEL=claude-haiku-4-5
#   CLAUDE_GROUP_REVIEWER_MODEL=claude-haiku-4-5
# Balance: Haiku generates, Sonnet audits:
#   CLAUDE_GROUP_GENERATOR_MODEL=claude-haiku-4-5
#   CLAUDE_GROUP_REVIEWER_MODEL=claude-sonnet-4-6
# Maximum quality / slowest: Opus generator (not recommended for batches)
#   CLAUDE_GROUP_GENERATOR_MODEL=claude-opus-4-7
#
# CLAUDE_GROUP_GENERATOR_MODEL=claude-sonnet-4-6
# CLAUDE_GROUP_REVIEWER_MODEL=claude-sonnet-4-6

# One-switch smaller drafts + trims (see agents/group_agents.py)
# ABUZAR_FAST=1

# Fine-grained speed (defaults are already faster than legacy 9-draft mode)
# ABUZAR_GENERATOR_CANDIDATES=4
# ABUZAR_CONCEPT_INSPIRATION_COUNT=10
# ABUZAR_GENERATOR_MAX_TOKENS=4096
# ABUZAR_AUDITOR_MAX_TOKENS=4096

# Fewer rows from data/groups.json embedded in prompts when the bank is huge (default 50).
# ABUZAR_EXISTING_GROUP_LIMIT=40

# Burak purple: classifier + selection (default = diversify purple roots)
# BURAK_PURPLE_SELECTION=pass_random   # random among ML scores ≥ threshold; else best score
# BURAK_PURPLE_SELECTION=best          # always highest score (legacy)
# BURAK_PURPLE_SELECTION=ignore        # skip classifier; random among collected candidates
# BURAK_PURPLE_CLASSIFIER_THRESHOLD=0.75

# Burak yellow: stronger model for titles, fewer retry loops (cost control)
# BURAK_YELLOW_LABEL_MODEL=claude-sonnet-4-6
# BURAK_YELLOW_VERIFY_MODEL=claude-sonnet-4-6
# BURAK_YELLOW_TITLE_MAX_TRIES=1
# BURAK_YELLOW_IMP2_TRIPLE_MAX_TRIES=4
# BURAK_YELLOW_LABEL_MAX_TOKENS=72
# BURAK_YELLOW_VERIFY_MAX_TOKENS=110
# BURAK_YELLOW_SEED_MAX_ATTEMPTS=20
# BURAK_IMP2_RECENT_COOLDOWN=10

# Burak green letter patterns: -tion/-sion groups off by default (set to 1 to restore)
# BURAK_GREEN_LETTER_ALLOW_TION=1
# Burak green meaningful-substring pools (short words like AIR/HAND/FIRE)
# BURAK_GREEN_WORD_SUBSTRING_MIN_POOL=6
# BURAK_GREEN_WORD_SUBSTRING_MAX_POOL=40
