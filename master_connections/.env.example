# Copy to `.env` and fill in (never commit `.env`).
# Used by master_connections/run.py via load_dotenv.

# Burak uses both; Abuzar AI (run_fresh_puzzle) uses Claude → ANTHROPIC_API_KEY required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional — Adreama / OpenAI chat defaults:
# OPENAI_CHAT_MODEL=gpt-4o

# Optional — Abuzar AI (subprocess inherits these from master_connections/.env via run.py load_dotenv)
#
# Fastest tiers (Anthropic IDs change over time — check docs):
#   CLAUDE_GROUP_GENERATOR_MODEL=claude-haiku-4-5
#   CLAUDE_GROUP_REVIEWER_MODEL=claude-haiku-4-5
# Balance: Haiku generates, Sonnet audits:
#   CLAUDE_GROUP_GENERATOR_MODEL=claude-haiku-4-5
#   CLAUDE_GROUP_REVIEWER_MODEL=claude-sonnet-4-6
# Maximum quality / slowest: Opus generator (not recommended for batches)
#   CLAUDE_GROUP_GENERATOR_MODEL=claude-opus-4-7
#
# CLAUDE_GROUP_GENERATOR_MODEL=claude-sonnet-4-6
# CLAUDE_GROUP_REVIEWER_MODEL=claude-sonnet-4-6

# One-switch smaller drafts + trims (see agents/group_agents.py)
# ABUZAR_FAST=1

# Fine-grained speed (defaults are already faster than legacy 9-draft mode)
# ABUZAR_GENERATOR_CANDIDATES=4
# ABUZAR_CONCEPT_INSPIRATION_COUNT=10
# ABUZAR_GENERATOR_MAX_TOKENS=4096
# ABUZAR_AUDITOR_MAX_TOKENS=4096

# Fewer rows from data/groups.json embedded in prompts when the bank is huge (default 50).
# ABUZAR_EXISTING_GROUP_LIMIT=40
